# Supabase project URL and service role key (NOT the anon key — service role bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# AES-256-GCM master key for encrypting agent private keys.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Losing this key = losing access to all agent wallets. Store it securely.
# WARNING: A leaked key = all agent wallets exposed. Use a KMS in production.
ENCRYPTION_KEY=replace_with_64_hex_characters_generated_by_node_command_above

# HTTP server port
PORT=3000

# Initial balance for new agents in lamports (1 SOL = 1,000,000,000 lamports)
# Default: 0.1 SOL = 100,000,000 lamports
INITIAL_AGENT_BALANCE=100000000

# Phase 3: task source selection.
# "dynamic" — use local simulator (DynamicTaskSource). No external deps.
# "http"    — use real external coordinator (HttpTaskSource). Requires COORDINATOR_URL.
TASK_SOURCE=dynamic

# URL of the task coordinator.
# In development: defaults to /external on this same process (http://localhost:3000/external).
# In production: point to the real external coordinator service.
# Only required when TASK_SOURCE=http.
COORDINATOR_URL=http://localhost:3000/external

# Amadeus REST API credentials (travel vertical: find_cheapest_flight, track_flight_price).
# Free sandbox registration at https://developers.amadeus.com — no credit card required.
# Sandbox uses test.api.amadeus.com (synthetic but structurally real flight data).
# If absent: travel tasks return infrastructure failure and refund cost. Server still starts.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Defaults to sandbox. Change to https://api.amadeus.com for production data.
AMADEUS_BASE_URL=https://test.api.amadeus.com
