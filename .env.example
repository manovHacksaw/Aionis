# Supabase project URL and service role key (NOT the anon key — service role bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# AES-256-GCM master key for encrypting agent private keys.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Losing this key = losing access to all agent wallets. Store it securely.
# WARNING: A leaked key = all agent wallets exposed. Use a KMS in production.
ENCRYPTION_KEY=replace_with_64_hex_characters_generated_by_node_command_above

# HTTP server port
PORT=3000

# Initial balance for new agents in lamports (1 SOL = 1,000,000,000 lamports)
# Default: 0.1 SOL = 100,000,000 lamports
INITIAL_AGENT_BALANCE=100000000
